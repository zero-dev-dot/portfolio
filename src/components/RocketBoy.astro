<div class="flex items-center justify-center w-full py-4 select-none pointer-events-none" aria-hidden="true">
  <img
    src="/rocketboy.png"
    alt="Rocket Boy shooting clouds"
    class="w-64 h-auto object-contain rounded-3xl"
    style="animation: gyroFloat 3.2s ease-in-out infinite;"
  />
</div>

<style>
  @keyframes gyroFloat {
    0%, 100% { transform: translateY(0px) rotate(-0.5deg); }
    50%       { transform: translateY(-10px) rotate(0.5deg); }
  }
</style>
