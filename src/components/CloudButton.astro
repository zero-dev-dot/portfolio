---
export interface Props { label: string; link: string; index?: number; }
const { label, link, index = 0 } = Astro.props;

const clouds = [
  `M 18,78 C 2,85 2,68 15,63 C 12,38 35,22 65,32 C 72,12 128,12 135,32 C 165,22 188,38 185,63 C 198,68 198,85 182,78 C 170,95 30,95 18,78 Z`,
  `M 20,78 C 2,85 2,68 14,63 C 8,44 26,32 48,38 C 54,18 88,12 105,32 C 122,14 158,20 162,46 C 178,44 192,60 184,74 C 178,92 28,95 20,78 Z`,
  `M 18,78 C 2,85 2,65 16,60 C 8,35 32,20 62,30 C 70,12 115,14 128,34 C 152,24 186,42 182,65 C 196,72 196,88 178,80 C 165,96 30,96 18,78 Z`,
  `M 20,78 C 4,86 3,66 16,61 C 10,40 32,26 55,36 C 60,14 98,10 114,30 C 132,12 165,26 160,52 C 178,50 194,65 184,76 C 175,94 28,95 20,78 Z`,
  `M 18,78 C 2,86 2,66 14,61 C 8,38 28,24 52,32 C 58,14 102,10 118,28 C 136,12 172,26 175,55 C 192,56 198,74 186,78 C 172,95 30,95 18,78 Z`,
];

const animations = [
  'float1 3.2s ease-in-out infinite',
  'float2 2.8s ease-in-out infinite',
  'float3 3.6s ease-in-out infinite',
  'float4 3.0s ease-in-out infinite',
  'float5 2.6s ease-in-out infinite',
];

const path = clouds[index % clouds.length];
const animation = animations[index % animations.length];
---
<a href={link} class="cloud-btn hover:text-red-500" style={`animation: ${animation}`}>
  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 200 100" class="cloud-svg">
    <path d={path} fill="white"/>
  </svg>
  <span class="cloud-label">{label}</span>
</a>

<style>
.cloud-btn {
  position: relative;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 220px;
  height: 150px;
  padding-top: 28px;
  text-decoration: none;
  filter: drop-shadow(0 8px 12px rgba(0,0,0,0.15));
}

.cloud-svg {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.cloud-label {
  position: relative;
  z-index: 1;
  font-size: 1.4rem;
  font-weight: 700;
  color: #29abe2;
  white-space: nowrap;
}
</style>
