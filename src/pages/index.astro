---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import Game from '../components/Game.astro';
import Title from '../components/Title.astro';

const skillGroups = [
  { label: 'Languages', items: ['JavaScript', 'TypeScript', 'Python', 'C++', 'SQL', 'Dart'] },
  { label: 'Frontend', items: ['React', 'Astro', 'HTML/CSS', 'Tailwind CSS'] },
  { label: 'Backend', items: ['Node.js', 'REST APIs', 'PostgreSQL', 'MySQL'] },
  { label: 'Mobile', items: ['Flutter', 'React Native'] },
  { label: 'ERP & Tools', items: ['1C', 'SAP', 'Odoo', 'Zoho', 'Git', 'Docker'] },
];

const experience = [
  { role: 'Backend Developer', company: 'Contract Projects', period: '2023 – Present',
    desc: 'Designed and developed backend services for web applications. Implemented REST APIs, handled database design, and ensured system scalability and performance. Integrated third-party services and optimized server-side logic.' },
  { role: 'Frontend Developer', company: 'Freelance Projects', period: '2022 – 2023',
    desc: 'Built responsive and user-friendly interfaces for web applications. Focused on clean UI, cross-browser compatibility, and performance optimization. Worked closely with backend systems and APIs.' },
  { role: 'ERP Integration Developer', company: 'Contract Projects', period: '2022 – 2023',
    desc: 'Integrated ERP systems (1C, SAP) with external services and internal tools. Automated business processes and improved data synchronization between systems.' },
  { role: 'Mobile App Developer', company: 'Freelance Projects', period: '2022 – 2023',
    desc: 'Developed mobile applications with API integration and user-focused design. Ensured smooth performance and usability across different devices.' },
  { role: 'C++ Developer', company: 'Independent Projects', period: '2021 – 2022',
    desc: 'Developed high-performance applications and utilities using C++. Focused on efficient data processing and system-level performance.' },
  { role: 'API & Integration Developer', company: 'Contract Projects', period: '2023 – Present',
    desc: 'Designed and implemented APIs for communication between services. Worked on authentication, data handling, and third-party integrations. Improved reliability and reduced response times.' },
  { role: 'Web Developer', company: 'Freelance', period: '2021 – 2022',
    desc: 'Created websites for small businesses, including landing pages and basic web systems. Focused on fast loading speed, responsive design, and SEO basics.' },
];

const projects = [
  { title: 'MVMT', url: 'https://www.mvmt.com/', desc: 'A modern e-commerce platform for watches and accessories with a clean, minimalist shopping experience.',
    tech: ['E-Commerce','UI/UX','Web'], cat: 'Web' },
  { title: 'Raycast', url: 'https://raycast.com/', desc: 'A blazing-fast productivity launcher with extensible plugins, script commands, and developer tools.',
    tech: ['Productivity','API','Extensions'], cat: 'Tool' },
  { title: 'Odoo', url: 'https://www.odoo.com/', desc: 'An open-source ERP platform covering CRM, sales, inventory, accounting, and business automation.',
    tech: ['ERP','Python','PostgreSQL'], cat: 'ERP' },
  { title: 'Zoho', url: 'https://www.zoho.com/', desc: 'A comprehensive suite of cloud business apps including CRM, HR, finance, and collaboration tools.',
    tech: ['SaaS','CRM','Cloud'], cat: 'ERP' },
  { title: 'Metabase', url: 'https://metabase.com/', desc: 'An open-source business intelligence tool for querying databases and building interactive dashboards without SQL.',
    tech: ['BI','Analytics','SQL'], cat: 'Tool' },
  { title: 'Allbirds', url: 'https://www.allbirds.com/', desc: 'A sustainable footwear e-commerce brand with a clean shopping experience and eco-focused product design.',
    tech: ['E-Commerce','Sustainability','Web'], cat: 'Web' },
];
---
<BaseLayout>
  <Navbar />

  <!-- Title -->
  <div class="pt-32 pb-4">
    <Title />
  </div>

  <!-- Hero + Game side by side -->
  <div class="flex flex-col lg:flex-row items-center justify-center gap-8 px-6 pt-16">
    <div class="flex-1">
      <Hero />
    </div>
    <div class="flex-1 flex items-center justify-center py-8">
      <Game />
    </div>
  </div>

  <!-- About -->
  <section id="about" class="max-w-4xl mx-auto px-6 py-20 mt-20 fade-in">
    <h2 class="text-3xl font-bold text-sky-900 border-b-4 border-sky-300 pb-2 inline-block mb-10">About Me</h2>
    <div class="flex flex-col md:flex-row gap-8 items-center">
      <img src="/profile.jpg" alt="Hiroshi Tanaka"
        class="w-40 h-40 rounded-full object-cover shadow-lg shrink-0" />
      <div>
        <p class="text-lg leading-relaxed mb-4">
          Hi! I'm <strong>Hiroshi Tanaka</strong>, a developer focused on building reliable, scalable, and efficient software solutions. I work across full-stack web development, mobile applications, and enterprise systems.
        </p>
        <p class="leading-relaxed mb-4">
          With experience in frontend, backend, and ERP platforms like 1C and SAP, I enjoy solving complex business problems and turning them into practical, well-structured systems. I'm especially interested in system architecture, performance optimization, and integration between services.
        </p>
        <p class="text-sky-700 leading-relaxed">
          When I'm not coding, I explore new technologies, improve my skills in backend and system design, and experiment with building tools that simplify real-world workflows.
        </p>
        <a href="https://docs.google.com/document/d/1LDhIWCCyTKUlCVnWwyDVKDJzvXro5uXidCDIbT6LZpI/edit?tab=t.0#heading=h.a0g2xijzwv6x" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 mt-5 text-sm font-medium text-white bg-sky-700 hover:bg-sky-900 px-5 py-2 rounded-full transition-colors no-underline">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v2a2 2 0 002 2h12a2 2 0 002-2v-2M7 10l5 5 5-5M12 15V3" />
          </svg>
          Download Resume
        </a>
      </div>
    </div>
  </section>

  <!-- Skills -->
  <section id="skills" class="max-w-4xl mx-auto px-6 py-20 bg-white/30 rounded-3xl fade-in">
    <h2 class="text-3xl font-bold text-sky-900 border-b-4 border-sky-300 pb-2 inline-block mb-10">Skills</h2>
    <div class="flex flex-col gap-6">
      {skillGroups.map(group => (
        <div>
          <p class="text-xs font-bold text-sky-500 uppercase tracking-widest mb-3">{group.label}</p>
          <div class="flex flex-wrap gap-2">
            {group.items.map(s => (
              <span class="bg-white text-sky-700 font-medium px-4 py-1.5 rounded-full shadow-sm text-sm">{s}</span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Experience -->
  <section id="experience" class="max-w-4xl mx-auto px-6 py-20 fade-in">
    <h2 class="text-3xl font-bold text-sky-900 border-b-4 border-sky-300 pb-2 inline-block mb-10">Experience</h2>
    <div class="border-l-4 border-sky-300 pl-6 space-y-8">
      {experience.map(e => (
        <div class="relative">
          <div class="absolute -left-[1.65rem] top-1 w-3 h-3 bg-sky-700 rounded-full"></div>
          <h3 class="text-lg font-semibold text-sky-900">{e.role} — {e.company}</h3>
          <span class="text-sm text-sky-500">{e.period}</span>
          <p class="mt-1 leading-relaxed text-slate-700">{e.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Projects -->
  <section id="work" class="max-w-4xl mx-auto px-6 py-20 bg-white/30 rounded-3xl fade-in">
    <h2 class="text-3xl font-bold text-sky-900 border-b-4 border-sky-300 pb-2 inline-block mb-2">Work & Integrations</h2>
    <p class="text-sm text-slate-500 mb-6">Platforms and systems I've worked with, integrated, or built on top of.</p>
    <div class="flex gap-2 mb-6 flex-wrap">
      {['All','Web','ERP','Tool'].map(cat => (
        <button class="filter-btn text-sm px-4 py-1.5 rounded-full border-2 border-sky-300 text-sky-700 font-medium transition-colors hover:bg-sky-700 hover:text-white" data-cat={cat}>
          {cat}
        </button>
      ))}
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 items-stretch" id="projects-grid">
      {projects.map(p => (
        <a href={p.url} target="_blank" rel="noopener noreferrer" data-cat={p.cat}
          class="project-card bg-white rounded-2xl overflow-hidden shadow-md hover:-translate-y-1 transition-transform duration-200 flex flex-col no-underline group">
          <div class="w-full h-36 overflow-hidden bg-sky-50 relative">
            <img
              src={`https://api.microlink.io/?url=${encodeURIComponent(p.url)}&screenshot=true&meta=false&embed=screenshot.url`}
              alt={p.title}
              class="w-full h-full object-cover object-top"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-sky-700/80 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-200">
              <span class="text-white font-semibold text-sm">View Live ↗</span>
            </div>
          </div>
          <div class="p-5 flex flex-col flex-1">
            <h3 class="text-lg font-bold text-sky-900 mb-1">{p.title} <span class="text-sky-400 text-sm font-normal">↗</span></h3>
            <p class="text-sm text-slate-600 leading-relaxed mb-3 flex-1">{p.desc}</p>
            <div class="flex flex-wrap gap-2">
              {p.tech.map(t => (
                <span class="bg-sky-100 text-sky-700 text-xs px-3 rounded-full h-7 flex items-center">{t}</span>
              ))}
            </div>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- Contact -->
  <section id="contact" class="max-w-4xl mx-auto px-6 py-20 fade-in">
    <h2 class="text-3xl font-bold text-sky-900 border-b-4 border-sky-300 pb-2 inline-block mb-10">Contact</h2>
    <div class="flex flex-col md:flex-row gap-12">
      <div class="flex flex-col gap-4 justify-start pt-1">
        <p class="text-slate-600 text-sm">Prefer to reach out directly?</p>
        <a href="mailto:thiroshi832@gmail.com" class="inline-flex items-center gap-2 text-sky-700 hover:text-sky-900 font-medium no-underline transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
          thiroshi832@gmail.com
        </a>
        <a href="https://t.me/tanaka601" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-sky-700 hover:text-sky-900 font-medium no-underline transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm5.894 8.221-1.97 9.28c-.145.658-.537.818-1.084.508l-3-2.21-1.447 1.394c-.16.16-.295.295-.605.295l.213-3.053 5.56-5.023c.242-.213-.054-.333-.373-.12L8.32 13.617l-2.96-.924c-.643-.204-.657-.643.136-.953l11.57-4.461c.537-.194 1.006.131.828.942z"/>
          </svg>
          @tanaka601 on Telegram
        </a>
      </div>
      <form class="flex flex-col gap-4 flex-1" id="contact-form" novalidate>
      <div class="flex flex-col gap-1">
        <input type="text" id="contact-name" placeholder="Your Name" minlength="2"
          class="px-4 py-3 rounded-xl border-2 outline-none text-base bg-white transition-colors" style="border-color: #bae6fd" />
        <span id="err-name" class="text-red-500 text-xs hidden"></span>
      </div>
      <div class="flex flex-col gap-1">
        <input type="email" id="contact-email" placeholder="Your Email"
          class="px-4 py-3 rounded-xl border-2 outline-none text-base bg-white transition-colors" style="border-color: #bae6fd" />
        <span id="err-email" class="text-red-500 text-xs hidden"></span>
      </div>
      <div class="flex flex-col gap-1">
        <textarea id="contact-message" placeholder="Your Message" minlength="10"
          class="px-4 py-3 rounded-xl border-2 outline-none text-base bg-white transition-colors min-h-32 resize-y" style="border-color: #bae6fd"></textarea>
        <span id="err-message" class="text-red-500 text-xs hidden"></span>
      </div>
      <button type="submit" id="contact-btn"
        class="bg-sky-700 hover:bg-sky-900 text-white font-semibold py-3 rounded-xl transition-colors duration-200">
        Send Message
      </button>
      </form>
    </div>
  </section>

  <footer class="text-center py-8 text-sky-700 text-sm">
    <div class="flex items-center justify-center gap-4 mb-2">
      <a href="https://t.me/tanaka601" target="_blank" rel="noopener noreferrer"
        class="inline-flex items-center gap-1.5 text-sky-700 hover:text-sky-900 transition-colors no-underline font-medium">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm5.894 8.221-1.97 9.28c-.145.658-.537.818-1.084.508l-3-2.21-1.447 1.394c-.16.16-.295.295-.605.295l.213-3.053 5.56-5.023c.242-.213-.054-.333-.373-.12L8.32 13.617l-2.96-.924c-.643-.204-.657-.643.136-.953l11.57-4.461c.537-.194 1.006.131.828.942z"/>
        </svg>
        @tanaka601
      </a>
    </div>
    © {new Date().getFullYear()} Hiroshi Tanaka. Built with Astro & Tailwind CSS.
  </footer>

  <!-- Toast -->
  <div id="toast" class="fixed bottom-6 left-1/2 -translate-x-1/2 bg-green-600 text-white px-6 py-3 rounded-full shadow-lg text-sm font-medium opacity-0 pointer-events-none transition-opacity duration-300 z-50"></div>

  <!-- Back to top -->
  <button id="back-top" class="fixed bottom-6 right-6 w-10 h-10 bg-sky-700 hover:bg-sky-900 text-white rounded-full shadow-lg flex items-center justify-center opacity-0 pointer-events-none transition-opacity duration-300 z-50 text-lg">
    ↑
  </button>
</BaseLayout>

<script>
  // Scroll fade-in
  const observer = new IntersectionObserver(entries => {
    entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); observer.unobserve(e.target); } });
  }, { threshold: 0.15 });
  document.querySelectorAll('.fade-in').forEach(el => observer.observe(el));

  // Back to top
  const backTop = document.getElementById('back-top')!;
  window.addEventListener('scroll', () => {
    backTop.style.opacity = window.scrollY > 400 ? '1' : '0';
    backTop.style.pointerEvents = window.scrollY > 400 ? 'auto' : 'none';
  });
  backTop.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));

  // Toast
  function showToast(msg: string, color = 'bg-green-600') {
    const t = document.getElementById('toast')!;
    t.textContent = msg;
    t.className = `fixed bottom-6 left-1/2 -translate-x-1/2 ${color} text-white px-6 py-3 rounded-full shadow-lg text-sm font-medium z-50 transition-opacity duration-300`;
    t.style.opacity = '1';
    setTimeout(() => { t.style.opacity = '0'; }, 3000);
  }

  // Project filter
  document.querySelectorAll('.filter-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const cat = (btn as HTMLElement).dataset.cat!;
      document.querySelectorAll('.filter-btn').forEach(b => {
        b.classList.remove('bg-sky-700', 'text-white');
        b.classList.add('text-sky-700');
      });
      btn.classList.add('bg-sky-700', 'text-white');
      btn.classList.remove('text-sky-700');
      document.querySelectorAll('.project-card').forEach(card => {
        const c = card as HTMLElement;
        c.style.display = (cat === 'All' || c.dataset.cat === cat) ? 'flex' : 'none';
      });
    });
  });
  // Set All active by default
  (document.querySelector('.filter-btn') as HTMLElement)?.click();

  // Contact form
  function showError(id: string, msg: string) {
    const el = document.getElementById(id)!;
    el.textContent = msg;
    el.classList.remove('hidden');
  }
  function clearError(id: string) {
    const el = document.getElementById(id)!;
    el.textContent = '';
    el.classList.add('hidden');
  }
  function setBorder(inputId: string, error: boolean) {
    const el = document.getElementById(inputId) as HTMLElement;
    el.style.borderColor = error ? '#f87171' : '#bae6fd';
  }
  function validateName() {
    const val = (document.getElementById('contact-name') as HTMLInputElement).value.trim();
    if (val.length < 2) { showError('err-name', 'Name must be at least 2 characters.'); setBorder('contact-name', true); return false; }
    clearError('err-name'); setBorder('contact-name', false); return true;
  }
  function validateEmail() {
    const val = (document.getElementById('contact-email') as HTMLInputElement).value.trim();
    if (!val || !/^[^@]+@[^@]+\.[^@]+$/.test(val)) { showError('err-email', 'Please enter a valid email address.'); setBorder('contact-email', true); return false; }
    clearError('err-email'); setBorder('contact-email', false); return true;
  }
  function validateMessage() {
    const val = (document.getElementById('contact-message') as HTMLTextAreaElement).value.trim();
    if (val.length < 10) { showError('err-message', 'Message must be at least 10 characters.'); setBorder('contact-message', true); return false; }
    clearError('err-message'); setBorder('contact-message', false); return true;
  }

  document.getElementById('contact-name')!.addEventListener('input', validateName);
  document.getElementById('contact-email')!.addEventListener('input', validateEmail);
  document.getElementById('contact-message')!.addEventListener('input', validateMessage);

  document.getElementById('contact-form')!.addEventListener('submit', async (e) => {
    e.preventDefault();
    const nameEl = document.getElementById('contact-name') as HTMLInputElement;
    const emailEl = document.getElementById('contact-email') as HTMLInputElement;
    const messageEl = document.getElementById('contact-message') as HTMLTextAreaElement;
    const btn = document.getElementById('contact-btn') as HTMLButtonElement;
    const ok = [validateName(), validateEmail(), validateMessage()].every(Boolean);
    if (!ok) return;

    btn.textContent = 'Sending...';
    btn.disabled = true;

    const res = await fetch('https://formspree.io/f/xnjgwvyq', {
      method: 'POST',
      headers: { 'Accept': 'application/json' },
      body: new URLSearchParams({ name: nameEl.value.trim(), email: emailEl.value.trim(), message: messageEl.value.trim() }),
    });

    const json = await res.json();

    if (res.ok) {
      btn.textContent = 'Send Message';
      btn.disabled = false;
      nameEl.value = ''; emailEl.value = ''; messageEl.value = '';
      clearError('err-name'); clearError('err-email'); clearError('err-message');
      setBorder('contact-name', false); setBorder('contact-email', false); setBorder('contact-message', false);
      showToast('Message sent! ✓');
    } else {
      btn.textContent = 'Send Message';
      btn.disabled = false;
      showToast('Failed to send. Try again.', 'bg-red-500');
    }
  });
</script>
