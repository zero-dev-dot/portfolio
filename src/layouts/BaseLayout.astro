---
export interface Props { title?: string; }
const { title = 'Hiroshi Tanaka | Full-Stack & Systems Developer' } = Astro.props;
import '../styles/global.css';
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Hiroshi Tanaka – Full-Stack & Systems Developer portfolio" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body class="min-h-screen bg-gradient-to-br from-sky-300 via-sky-200 to-blue-100 text-slate-800 font-sans">
    <slot />
  </body>
</html>
